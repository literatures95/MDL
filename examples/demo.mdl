# MDL 示例脚本 - 演示所有核心功能

// ============================================
// 1. 加载 Markdown 文件
// ============================================
load "example.md" as doc

// ============================================
// 2. 读取和显示文档信息
// ============================================
print "=== 文档概览 ==="
print "总元素数: " + len(doc.children)
print "标题数量: " + len(select(doc, "heading"))

// ============================================
// 3. 遍历并打印所有标题
// ============================================
print "\n=== 文档标题 ==="
for h in select(doc, "heading"):
    print "#"*h.level + " " + h.text
end

// ============================================
// 4. 修改标题内容
// ============================================
set doc.h1[0].text = "修改后的一级标题"
print "\n修改后的第一个标题: " + doc.h1[0].text

// ============================================
// 5. 在指定位置插入内容
// ============================================
insert after doc.h1[0]:
  "这是通过 MDL 插入的新段落，展示了 insert 命令的强大功能。"

// ============================================
// 6. 追加新元素到文档末尾
// ============================================
append:
  - 新增列表项 A
  - 新增列表项 B
  - 新增列表项 C

// ============================================
// 7. 追加代码块
// ============================================
append codeblock "python":
  def hello_mdl():
      print("Hello from MDL!")
      return "MDL is awesome!"

// ============================================
// 8. 文档分析
// ============================================
print "\n=== 文档分析 ==="
analysis = analyze(doc)
print "段落数: " + analysis.content.paragraph_count
print "字数统计: " + analysis.content.word_count
print "可读性评分: " + analysis.readability.score
print "健康状态: " + analysis.health.status

// ============================================
// 9. 格式转换
// ============================================
convert doc to html save as "example_output.html"
convert doc to json save as "example_output.json"

// ============================================
// 10. 自定义函数示例
// ============================================
func extract_all_links(document):
    links = []
    for child in document.children:
        // 递归提取链接逻辑
        print child.type
    end
    return links
end

// ============================================
// 11. 条件判断示例
// ============================================
if len(doc.children) > 5:
    print "文档内容丰富!"
else:
    print "文档较简单"
end

// ============================================
// 12. 保存修改后的文档
// ============================================
save doc as "modified_example.md"

print "\n=== 执行完成 ==="
